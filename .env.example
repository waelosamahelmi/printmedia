# Database - Hostinger MySQL
# Get these values from Hostinger hPanel -> Databases -> MySQL
DATABASE_URL="mysql://u123456789_admin:your-password@localhost:3306/u123456789_printmedia"

# NextAuth Configuration
NEXTAUTH_SECRET="generate-a-32-character-random-string-here"
NEXTAUTH_URL="https://www.printmedia.fi"

# Site URL
NEXT_PUBLIC_SITE_URL="https://www.printmedia.fi"

# Admin Email (for initial setup)
ADMIN_EMAIL="admin@printmedia.fi"

# Contact form email (Hostinger SMTP)
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="no-reply@printmedia.fi"
SMTP_PASSWORD="your-smtp-password"

# Optional overrides for contact form recipient/sender
CONTACT_TO_EMAIL="myynti@printmedia.fi"
CONTACT_FROM_EMAIL="no-reply@printmedia.fi"
